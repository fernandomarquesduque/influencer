# Instagram (obrigatório para login)
INSTAGRAM_USER=
# Senha com # ou & etc: use aspas duplas, ex: INSTAGRAM_PASSWORD="sua#senha&aqui"
INSTAGRAM_PASSWORD=

# Limites por execução
MAX_POSTS_PER_TAG=30
MAX_PROFILES=100

# Playwright
HEADFUL=false
# LOGIN_DEBUG=true

# Caminho da sessão persistida (opcional)
AUTH_STATE_PATH=.auth/instagram.json
