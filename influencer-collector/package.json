{
  "name": "influencer-collector",
  "version": "1.0.0",
  "description": "Coletor de influenciadores em memória — browser abre no Instagram; usuário navega e liga a coleta quando quiser (Mac/Windows)",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "package:mac": "bash scripts/package-mac.sh",
    "package:mac-share": "pwsh -ExecutionPolicy Bypass -File scripts/package-mac-share.ps1",
    "package:windows": "pwsh -ExecutionPolicy Bypass -File scripts/package-win.ps1",
    "start": "node --max-old-space-size=8192 ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "collect": "node --max-old-space-size=8192 ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "watchdog": "pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/run-collector-watchdog.ps1",
    "watchdog:unix": "bash scripts/run-collector-watchdog.sh",
    "verify": "tsx src/scripts/verify.ts",
    "test": "npm run build && npm run verify"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.4.5",
    "franc": "^6.2.0",
    "playwright": "^1.49.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
