# Instagram — sessão salva automaticamente após login (reabre logado na próxima vez)
# Padrão: data/instagram-auth.json (pasta data/ no .gitignore)
# AUTH_STATE_PATH=data/instagram-auth.json

# Google (modo busca) — cookies salvos após resolver captcha/consentimento (evita na próxima vez)
# GOOGLE_SESSION_PATH=data/google-session.json

# Regras de coleta (padrão; também ajustáveis na interface web)
# MIN_FOLLOWERS=5000
# MAX_FOLLOWERS=1000000   — padrão 1M; 0 = sem limite
# MIN_POST_LIKES=200
# MIN_POSTS_WITH_MIN_LIKES=4
# EXCLUDE_BUSINESS_PROFILES=true

# Bio em pt-BR (franc + heurísticas). false = não rejeita por idioma.
# COLLECTOR_REQUIRE_BIO_PT_BR=false
# Com regra ligada: bio com menos de N caracteres úteis (sem URL/@) conta como pt-BR (padrão N=22). 0 = sempre analisar idioma.
# COLLECTOR_BIO_PT_BR_MIN_USEFUL_CHARS=22

# Browser (por padrão a janela aparece — faça login manual no Instagram)
# HEADLESS=true   — só se quiser rodar sem ver o browser
# PLAYWRIGHT_CHROME_CHANNEL=chrome   — usar Chrome instalado (Mac/Windows)
# PLAYWRIGHT_CHROMIUM_EXECUTABLE=/caminho/para/chromium

# Interface da coleta
# COLLECTOR_UI_PORT=3967
# Problemas (erros) — SQLite local (recomendado). Migração: se existir o JSON antigo, importa uma vez e renomeia .bak
# COLLECTOR_ISSUES_DB_PATH=data/collector-issues.sqlite
# Caminho apenas para migração + vizinho do .jsonl (legado)
# COLLECTOR_ISSUES_PATH=data/collector-issues.json
# Log append-only com TODOS os problemas (uma linha JSON por registro). Padrão: ligado → data/collector-issues-append.jsonl (ou pasta do COLLECTOR_ISSUES_PATH)
# COLLECTOR_ISSUES_APPEND=off
# COLLECTOR_ISSUES_APPEND_PATH=data/meus-problemas.jsonl

# Enviar perfis coletados para o RocksDB no servidor (API em produção)
# OBRIGATÓRIO incluir /api (IIS Application). Ex.: https://buscainfluencer.com.br/api
# Use https e a URL final (sem redirecionamento): http→https fazia o Node trocar POST por GET e a API respondia "Cannot GET …/collector-ingest-full".
# Só domínio (https://buscainfluencer.com.br) fazia POST no site errado — o coletor agora acrescenta /api automaticamente.
# COLLECTOR_API_BASE=https://buscainfluencer.com.br/api
# Se a API não usa /api: COLLECTOR_API_NO_AUTO_SUFFIX=true
# Mesmo valor de COLLECTOR_INGEST_SECRET no .env do servidor crawl
# COLLECTOR_INGEST_KEY=sua-chave-secreta-longa
# Timeout do POST (ms) — sem isso o Node podia esperar para sempre e a coleta “parava”
# COLLECTOR_API_TIMEOUT_SLIM_MS=120000
# COLLECTOR_API_TIMEOUT_FULL_MS=600000
# Após POST OK, o collector chama GET collector-verify-profile (confirma RocksDB). Multi-worker IIS: COLLECTOR_SKIP_VERIFY=true
# COLLECTOR_SKIP_VERIFY=true
# COLLECTOR_VERIFY_TIMEOUT_MS=20000
# Antes de extrair no Instagram: consulta a mesma rota; se o @ já existir no RocksDB, pula o perfil (false = desliga)
# COLLECTOR_SKIP_IF_ALREADY_IN_DB=false
