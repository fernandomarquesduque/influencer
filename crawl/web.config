<?xml version="1.0" encoding="utf-8"?>
<!--
  Configuração iisnode para a API influencer.
  No IIS: crie uma Application com alias "api", path /api e esta pasta (crawl) como physical path.
  Antes do deploy: na pasta crawl rode "npm run build" para gerar dist/ e "npm ci" para node_modules.
-->
<configuration>
  <system.webServer>
    <webSocket enabled="false" />
    <handlers>
      <add name="iisnode" path="run.mjs" verb="*" modules="iisnode" />
    </handlers>
    <rewrite>
      <rules>
        <rule name="NodeInspector" patternSyntax="ECMAScript" stopProcessing="true">
          <match url="^run\.mjs\/debug[\/]?" />
        </rule>
        <rule name="DynamicContent">
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="run.mjs" />
        </rule>
      </rules>
    </rewrite>
    <security>
      <requestFiltering>
        <hiddenSegments>
          <remove segment="bin" />
        </hiddenSegments>
        <requestLimits maxAllowedContentLength="4294967295" />
      </requestFiltering>
    </security>
    <httpErrors existingResponse="PassThrough" />
    <iisnode watchedFiles="web.config;run.mjs;dist\**\*" loggingEnabled="true" />
  </system.webServer>
</configuration>
