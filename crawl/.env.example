# API
API_PORT=3500

# Proteção contra crawlers e extração em massa
# Limite diário de buscas para anônimos/usuários public (padrão 50)
# API_PUBLIC_MAX_REQUESTS_PER_DAY=50
# Requisições por minuto por IP quando não logado (padrão 30)
# API_RATE_LIMIT_PER_MIN_IP=30
# Requisições por minuto por usuário public/influencer (padrão 60)
# API_RATE_LIMIT_PER_MIN_USER=60
# Requisições por minuto para adm/assinante (padrão 120)
# API_RATE_LIMIT_PER_MIN_SUBSCRIBER=120

# Banco (caminhos relativos à pasta crawl)
STORAGE_DB_PATH=./data/rocksdb
SQLITE_DB_PATH=./data/influencer.db

# Autenticação JWT (obrigatório em produção; mínimo 16 caracteres)
JWT_SECRET=dev-secret-change-in-production-min-16-chars

# Instagram (para login/crawl)
INSTAGRAM_USER=
INSTAGRAM_PASSWORD=

# Opcional: estado da sessão Instagram
# AUTH_STATE_PATH=.auth/instagram.json

# Delay entre extrações de perfil na API (reduz bloqueio). Padrão 8–20 s.
# MIN_DELAY_MS=8000
# MAX_DELAY_MS=20000
# Cooldown a cada N perfis (pausa 1–3 min). 0 = desligado.
# COOLDOWN_EVERY=10
# COOLDOWN_MIN_MS=60000
# COOLDOWN_MAX_MS=180000

# Opcional: Playwright — Chromium na pasta do projeto (não usa Chrome do sistema)
# PLAYWRIGHT_BROWSERS_PATH=./browser
# Depois: npx playwright install chromium
# PLAYWRIGHT_LAUNCH_TIMEOUT=60000
# Ou caminho direto para o executável:
# PLAYWRIGHT_CHROMIUM_EXECUTABLE=./browser/chromium-1234/chrome-win/chrome.exe

# Opcional: produção
# NODE_ENV=production
