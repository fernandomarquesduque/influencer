{
  "openapi": "3.0.3",
  "info": {
    "title": "Influencer API",
    "description": "API para consultar perfis e posts armazenados no banco (RocksDB).",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Local"
    }
  ],
  "paths": {
    "/api/profiles": {
      "get": {
        "summary": "Lista todos os perfis",
        "tags": [
          "Perfis"
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            },
            "description": "Máximo de itens"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Offset para paginação"
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de perfis",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": {
                      "type": "integer"
                    },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "description": "Perfil (entidade dinâmica)"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/profiles/search": {
      "get": {
        "summary": "Lista perfis com filtros e engajamento",
        "description": "Filtros avançados e cálculo de engajamento baseado nos posts (likes, comentários). Retorna engagement_rate, total_likes, avg_likes, etc.",
        "tags": [
          "Perfis"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Busca em handle, username, full_name"
          },
          {
            "name": "minFollowers",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Mínimo de seguidores"
          },
          {
            "name": "maxFollowers",
            "in": "query",
            "schema": {
              "type": "integer"
            },
            "description": "Máximo de seguidores"
          },
          {
            "name": "categories",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Categorias separadas por vírgula"
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "enum": [
                "engagement_desc",
                "engagement_asc",
                "followers_desc",
                "followers_asc"
              ],
              "default": "engagement_desc"
            },
            "description": "Ordenação"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista com perfis e engagement",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": {
                      "type": "integer"
                    },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "key": {
                            "type": "string"
                          },
                          "handle": {
                            "type": "string"
                          },
                          "full_name": {
                            "type": "string"
                          },
                          "followers_count": {
                            "type": "integer"
                          },
                          "engagement": {
                            "type": "object",
                            "properties": {
                              "posts_count": {
                                "type": "integer"
                              },
                              "total_likes": {
                                "type": "integer"
                              },
                              "total_comments": {
                                "type": "integer"
                              },
                              "engagement_rate": {
                                "type": "number"
                              },
                              "avg_likes": {
                                "type": "number"
                              },
                              "avg_comments": {
                                "type": "number"
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/profiles/{handle}": {
      "get": {
        "summary": "Busca um perfil por handle",
        "tags": [
          "Perfis"
        ],
        "parameters": [
          {
            "name": "handle",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Handle do perfil (ex: mala.ta.ok)"
          }
        ],
        "responses": {
          "200": {
            "description": "Perfil encontrado",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "description": "Entidade dinâmica do perfil"
                }
              }
            }
          },
          "404": {
            "description": "Perfil não encontrado"
          }
        }
      }
    },
    "/api/posts": {
      "get": {
        "summary": "Lista todos os posts",
        "tags": [
          "Posts"
        ],
        "parameters": [
          {
            "name": "profile",
            "in": "query",
            "schema": {
              "type": "string"
            },
            "description": "Filtrar por handle do perfil"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 50
            }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de posts",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": {
                      "type": "integer"
                    },
                    "items": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "description": "Post (entidade dinâmica)"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/buckets/{bucket}": {
      "get": {
        "summary": "Lista chaves de um bucket",
        "tags": [
          "Buckets"
        ],
        "parameters": [
          {
            "name": "bucket",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "profile",
                "post"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Lista de chaves",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "bucket": {
                      "type": "string"
                    },
                    "keys": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/clear": {
      "delete": {
        "summary": "Remove todos os dados do banco",
        "description": "Apaga todos os registros (perfis e posts) do RocksDB. Use com cuidado.",
        "tags": [
          "Sistema"
        ],
        "responses": {
          "200": {
            "description": "Banco limpo",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    },
                    "message": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          },
          "500": {
            "description": "Erro ao limpar (ex.: banco em uso)"
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "summary": "Health check",
        "tags": [
          "Sistema"
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/crawl/status": {
      "get": {
        "summary": "Status do crawl",
        "description": "Indica se há um crawl em execução e o resultado do último crawl (quando existir).",
        "tags": [
          "Crawl"
        ],
        "responses": {
          "200": {
            "description": "Status atual",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "running": {
                      "type": "boolean",
                      "description": "True se um crawl está em andamento"
                    },
                    "last": {
                      "type": "object",
                      "properties": {
                        "saved": {
                          "type": "integer"
                        },
                        "tag": {
                          "type": "string"
                        },
                        "finishedAt": {
                          "type": "string",
                          "format": "date-time"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/crawl": {
      "post": {
        "summary": "Inicia um crawl por hashtag",
        "description": "Dispara o crawl no mesmo processo da API (compartilha o RocksDB). Resposta 202 = aceito; o crawl roda em background. Use GET /api/crawl/status para acompanhar.",
        "tags": [
          "Crawl"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "tag"
                ],
                "properties": {
                  "tag": {
                    "type": "string",
                    "description": "Hashtag sem # (ex: viagem)"
                  },
                  "limit": {
                    "type": "integer",
                    "description": "Máximo de perfis a processar (opcional)"
                  },
                  "clear": {
                    "type": "boolean",
                    "description": "Se true, limpa o banco antes de começar (opcional)"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Crawl iniciado em background",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "started": {
                      "type": "boolean"
                    },
                    "tag": {
                      "type": "string"
                    },
                    "limit": {
                      "type": [
                        "integer",
                        "null"
                      ]
                    },
                    "clear": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Body inválido (tag ausente)"
          },
          "409": {
            "description": "Já existe um crawl em andamento"
          }
        }
      }
    },
    "/api/admin/db/tables": {
      "get": {
        "summary": "Lista tabelas do banco",
        "description": "Retorna as tabelas permitidas para consulta. Requer scope adm.",
        "tags": [
          "Admin - Banco"
        ],
        "responses": {
          "200": {
            "description": "Lista de tabelas",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tables": {
                      "type": "array",
                      "items": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/admin/db/tables/{table}": {
      "get": {
        "summary": "Consulta tabela",
        "description": "Retorna linhas da tabela com paginação. password_hash de auth_user é ocultado. Requer scope adm.",
        "tags": [
          "Admin - Banco"
        ],
        "parameters": [
          {
            "name": "table",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "auth_user",
                "auth_public_request",
                "auth_anonymous_request",
                "auth_profile_verification",
                "profiles",
                "post",
                "profile_activation"
              ]
            },
            "description": "Nome da tabela"
          },
          {
            "name": "limit",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 100,
              "maximum": 1000
            },
            "description": "Máximo de linhas"
          },
          {
            "name": "offset",
            "in": "query",
            "schema": {
              "type": "integer",
              "default": 0
            },
            "description": "Offset"
          }
        ],
        "responses": {
          "200": {
            "description": "Linhas da tabela",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "table": {
                      "type": "string"
                    },
                    "rows": {
                      "type": "array",
                      "items": {
                        "type": "object"
                      }
                    },
                    "total": {
                      "type": "integer"
                    },
                    "limit": {
                      "type": "integer"
                    },
                    "offset": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Perfis",
      "description": "Perfis de influenciadores"
    },
    {
      "name": "Posts",
      "description": "Posts dos perfis"
    },
    {
      "name": "Buckets",
      "description": "Chaves por bucket"
    },
    {
      "name": "Sistema",
      "description": "Endpoints de sistema"
    },
    {
      "name": "Crawl",
      "description": "Iniciar e consultar status do crawl por hashtag (mesmo processo da API)"
    },
    {
      "name": "Admin - Banco",
      "description": "Consulta às tabelas do SQLite (requer adm)"
    }
  ]
}