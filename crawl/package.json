{
  "name": "influencer-extractor",
  "version": "1.0.0",
  "description": "Extração de microinfluenciadores Instagram com foco em endereço e baixo uso de memória",
  "type": "module",
  "scripts": {
    "build": "tsc && node -e \"require('fs').cpSync('src/api/openapi-rocksdb.json', 'dist/api/openapi-rocksdb.json'); require('fs').cpSync('src/api/openapi-sqlite.json', 'dist/api/openapi-sqlite.json')\"",
    "extract": "tsx src/cli/crawl-hashtag.ts -- --limit 30",
    "extract-feed": "tsx src/cli/crawl-feed.ts",
    "extract-explore": "tsx src/cli/crawl-explore.ts",
    "extract-all": "tsx src/cli/crawl-all.ts",
    "login": "tsx src/cli/login.ts",
    "list-db": "tsx src/cli/list-db.ts",
    "check-db": "tsx src/cli/check-db.ts",
    "follow-my-followers": "tsx src/cli/follow-my-followers.ts",
    "api": "tsx src/api/server.ts",
    "create-admin": "tsx src/scripts/create-admin.ts",
    "create-admin:server": "node dist/scripts/create-admin.js",
    "seed-projects": "tsx scripts/seed-projects.ts",
    "router-port-forward": "tsx src/scripts/router-port-forward.ts",
    "test:request-code": "tsx scripts/test-request-code-with-extract.ts"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "level": "^10.0.0",
    "playwright": "^1.49.0",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/swagger-ui-express": "^4.1.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}