# API
API_PORT=3500

# Aquecer cache de busca na subida (todos os perfis + posts em RAM — rápido, mas exige mais memória).
# Em servidores com pouca RAM ou muitos registros, use false e deixe o npm script "api" com heap maior se precisar.
# API_WARM_SEARCH_CACHE=false

# Se o aquecimento na subida falhar (RocksDB em lock), intervalo entre tentativas em ms até liberar (default 2500).
# SEARCH_CACHE_WARM_RETRY_MS=2500

# Logs [mem]: rss, heap, v8_heap_limit_mb (confirme ~16384 no IIS via run.mjs). Desligar: MEMORY_DIAG=false
# Durante capas S3, log a cada N uploads ok (default 10); só início/fim: MEM_DIAG_S3_COVER_EVERY=0
# MEMORY_DIAG=false
# MEM_DIAG_S3_COVER_EVERY=10

# IIS (run.mjs): heap do worker em MiB — precisa bater com v8_heap_limit_mb nos logs
# NODE_HEAP_MB=16384

# URL do frontend (links de verificação de e-mail, redirects). Fallback: VITE_APP_URL ou http://localhost:5173
# FRONTEND_BASE_URL=https://seu-dominio.com

# Rate limit de busca (anônimo / scope public): janela em minutos (padrão 10) e máx. de buscas na janela (padrão 5).
# API_RATE_LIMIT_PUBLIC_SEARCH_WINDOW_MINUTES=10
# API_RATE_LIMIT_PUBLIC_SEARCH_PER_HOUR=5
# Legado: PUBLIC_SEARCH_LIMIT_PER_HOUR=5
# Requisições por minuto na API de dados (post-matches, profiles, etc.)
# API_RATE_LIMIT_PER_MIN_IP=600
# API_RATE_LIMIT_PER_MIN_USER=600
# API_RATE_LIMIT_PER_MIN_SUBSCRIBER=1200

# Secret para o influencer-collector local enviar perfis (POST .../crawl/collector-ingest-profile, header X-Collector-Key)
# COLLECTOR_INGEST_SECRET=

# Banco (caminhos relativos à pasta backend)
STORAGE_DB_PATH=./data/rocksdb
SQLITE_DB_PATH=./data/influencer.db

# Meilisearch (opcional) — busca textual com typo/relevância; exige servidor Meili
# MEILISEARCH_HOST=http://127.0.0.1:7700
# MEILISEARCH_API_KEY=
# MEILISEARCH_SEARCH=1
# MEILISEARCH_SYNC=0

# Marca tempos no console para GET de busca (debug)
# SEARCH_PROFILE_TIMING=1

# Cache em memória de GET /api/admin/stats (contagem RocksDB é lenta). Padrão 60000 ms. Ignorar cache: ?fresh=1
# ADMIN_STATS_CACHE_TTL_MS=60000

# Autenticação JWT (obrigatório em produção; mínimo 16 caracteres)
JWT_SECRET=dev-secret-change-in-production-min-16-chars

# Instagram (para login/crawl)
INSTAGRAM_USER=
INSTAGRAM_PASSWORD=

# Opcional: estado da sessão Instagram
# AUTH_STATE_PATH=data/instagram-auth.json

# Delay entre extrações de perfil na API (reduz bloqueio). Padrão 8–20 s.
# MIN_DELAY_MS=8000
# MAX_DELAY_MS=20000
# Cooldown a cada N perfis (pausa 1–3 min). 0 = desligado.
# COOLDOWN_EVERY=10
# COOLDOWN_MIN_MS=60000
# COOLDOWN_MAX_MS=180000

# Auto-exclusão após falha de extração (protegido por trava; padrão = exclusão real)
# Perfis com avatar e capas estáveis no S3 nunca são excluídos (em qualquer motivo).
# Motivos: not_found, private, api_no_s3 (falha API sem dados + perfil sem mídia S3)
# EXTRACT_AUTO_DELETE_ENABLED=true
# EXTRACT_AUTO_DELETE_DRY_RUN=true   # opcional: só simula, não apaga (para testes)
# EXTRACT_AUTO_DELETE_REQUIRED_CONSECUTIVE=1
# EXTRACT_AUTO_DELETE_MAX_PER_RUN=20
# EXTRACT_AUTO_DELETE_MAX_PERCENT_PER_RUN=0.5
# EXTRACT_AUTO_DELETE_REASONS=not_found,private,api_no_s3

# Opcional: Playwright — Chromium na pasta do projeto (não usa Chrome do sistema)
# PLAYWRIGHT_BROWSERS_PATH=./browser
# Depois: npx playwright install chromium
# PLAYWRIGHT_LAUNCH_TIMEOUT=60000
# Ou caminho direto para o executável:
# PLAYWRIGHT_CHROMIUM_EXECUTABLE=./browser/chromium-1234/chrome-win/chrome.exe

# Duração do acesso ao relatório de campanha em dias (padrão 365). Usado no servidor ao criar campanha e exposto em GET /api/campaign-access-defaults para o front.
# CAMPAIGN_ACCESS_DURATION_DAYS=365

# Pagamentos (Asaas) — compra de créditos
# Preço por crédito em centavos (padrão 100 = R$ 1,00)
# CREDITS_PRICE_CENTS=100
# Dias de trial no checkout de plano (primeira cobrança Asaas = hoje + N). Padrão 7. Use 0 para cobrar já na criação.
# BUSCA_PLAN_TRIAL_DAYS=7
# Opcional no frontend (Vite): exibir os mesmos N dias na página de checkout. Se omitido, o front usa 7.
# VITE_BUSCA_PLAN_TRIAL_DAYS=7
# Webhook Asaas: configurar no painel a URL https://seu-dominio/api/payments/webhook para evento PAYMENT_RECEIVED/PAYMENT_CONFIRMED

# Asaas — produção (padrão). Para sandbox: ASAAS_ENV=sandbox e URL/chave do painel sandbox.
ASAAS_ENV=production
ASAAS_BASE_URL=https://api.asaas.com/v3
ASAAS_API_KEY=sua_api_key_producao
# ASAAS_ENV=sandbox
# ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# ASAAS_API_KEY=sua_api_key_sandbox
# Logar no console o JSON retornado pelo Asaas (criar cobrança, GET payment, pixQrCode). Em produção, só com esta flag.
# ASAAS_DEBUG=1

# E-mail (validação de conta) — obrigatório para o link de verificação chegar por e-mail.
# Sem SMTP configurado, o link só aparece no console do servidor (npm run dev / node).
# SMTP_HOST=email-ssl.com.br
# SMTP_PORT=465
# SMTP_USER=ola@buscainfluencer.com.br
# SMTP_PASS=Buscainfluencer1234!
# MAIL_FROM=ola@buscainfluencer.com.br
# Testar envio: npm run test:email -- seu@email.com

# Opcional: produção
# NODE_ENV=production

# --- S3: foto de perfil estável (uma pasta por handle: influencers/<handle>/avatar.*) ---
# Não commite credenciais. Use IAM com permissão mínima (s3:PutObject, s3:HeadBucket, s3:CreateBucket se necessário).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=sa-east-1
# Nome do bucket — OBRIGATÓRIO usar um nome único SEU (o padrão "influencer" quase sempre já existe em outra conta).
# AWS_S3_BUCKET=creait
# ou: AWS_BUCKET_NAME=creait
# URL pública custom (CDN), sem barra final
# AWS_S3_PUBLIC_BASE_URL=https://cdn.exemplo.com
# Só use se o bucket tiver ACLs habilitadas (Object Ownership ≠ "Bucket owner enforced").
# Com ACLs desligadas na AWS, definir isto causa erro — deixe comentado e use política de bucket para leitura pública.
# AWS_S3_OBJECT_ACL=public-read
#
# Otimização do avatar antes do upload (Sharp → WebP/JPEG leve)
# S3_AVATAR_RAW=true
# S3_AVATAR_MAX_EDGE=384
# S3_AVATAR_FORMAT=webp
# S3_AVATAR_WEBP_QUALITY=78
# S3_AVATAR_JPEG_QUALITY=80
#
# Antes de cada novo lote de mídia no DB: apaga todo o prefixo influencers/<handle>/ no S3, depois reenvia avatar + capas.
# S3_INFLUENCER_WIPE_DISABLE=true — não apaga o prefixo (não recomendado: sobram órfãos)
# S3_POST_COVER_DISABLE=true — não faz upload das capas (só avatar após wipe)
# S3_POST_RAW=true
# S3_POST_MAX_EDGE=720
# S3_POST_FORMAT=webp
# S3_POST_WEBP_QUALITY=76
# S3_POST_JPEG_QUALITY=78
# IAM: além de PutObject, use ListBucket (prefixo) e DeleteObject para o wipe.
