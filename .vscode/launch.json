{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Backend API (watch)",
            "runtimeExecutable": "C:\\Program Files\\nodejs\\node.exe",
            "runtimeArgs": [
                "--max-old-space-size=16384",
                "${workspaceFolder}/backend/node_modules/tsx/dist/cli.mjs",
                "watch",
                "src/api/server.ts"
            ],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "preLaunchTask": "prelaunch-backend",
            "presentation": {
                "group": "dev",
                "order": 1
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Backend API (sem watch)",
            "runtimeExecutable": "C:\\Program Files\\nodejs\\node.exe",
            "runtimeArgs": [
                "--max-old-space-size=16384",
                "${workspaceFolder}/backend/node_modules/tsx/dist/cli.mjs",
                "src/api/server.ts"
            ],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "preLaunchTask": "prelaunch-backend",
            "presentation": {
                "group": "dev",
                "order": 2
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Frontend",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "cwd": "${workspaceFolder}/frontend",
            "console": "integratedTerminal",
            "presentation": {
                "group": "dev",
                "order": 3
            }
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Extract",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "extract",
                "--",
                "--delay-extra",
                "1000"
            ],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal",
            "preLaunchTask": "kill-extract"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Extract Feed",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "extract-feed",
                "--",
                "--limit",
                "30",
                "--delay-extra",
                "1000"
            ],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Extract Explore",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "extract-explore",
                "--",
                "--limit",
                "30",
                "--delay-extra",
                "1000"
            ],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Extract All (Hashtag → Feed → Explore)",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "extract-all",
                "--",
                "--limit",
                "10",
                "--delay-extra",
                "1000"
            ],
            "cwd": "${workspaceFolder}/backend",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Qualify UI",
            "runtimeExecutable": "npm",
            "runtimeArgs": [
                "run",
                "ui"
            ],
            "cwd": "${workspaceFolder}/qualify",
            "console": "integratedTerminal"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "program": "${file}",
            "outFiles": [
                "${workspaceFolder}/**/*.js"
            ]
        }
    ],
    "compounds": [
        {
            "name": "Dev: API (watch) + Frontend",
            "configurations": [
                "Backend API (watch)",
                "Frontend"
            ],
            "preLaunchTask": "kill-api-and-frontend",
            "stopAll": true,
            "presentation": {
                "group": "dev",
                "order": 1
            }
        }
    ]
}
