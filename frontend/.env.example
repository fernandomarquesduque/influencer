# --- Desenvolvimento local (npm run dev) ---
# Proxy do Vite: requisições a /api são encaminhadas para este host.
# Produção:
VITE_API_PROXY_TARGET=https://buscainfluencer.com.br
# Backend local (comente a linha acima e use):
# VITE_API_PROXY_TARGET=http://localhost:3500

# --- Build (npm run build / IIS) ---
# API no mesmo domínio do site (padrão /api). Só altere em subpasta:
# VITE_API_BASE=/influencer/api
# VITE_BASE_PATH=/influencer/

# Opcional
# VITE_AGENCY_WHATSAPP=5511999999999
# VITE_BUSCA_PLAN_TRIAL_DAYS=7
