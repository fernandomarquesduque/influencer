<?xml version="1.0" encoding="UTF-8"?>
<!--
  Para admin/assinante ver dados completos (sem _redacted): o IIS precisa repassar o header Authorization.
  No servidor: IIS Manager -> Site -> URL Rewrite -> View Server Variables -> Add "HTTP_AUTHORIZATION".
  Depois edite a regra "Proxy API": em Action, em Server Variables adicione HTTP_AUTHORIZATION = {HTTP_Authorization}.
  (Fazer no IIS Manager evita 500 por allowedServerVariables em alguns ambientes.)
-->
<configuration>
  <system.webServer>
    <rewrite>
      <rules>
        <!-- Redireciona HTTP para HTTPS -->
        <rule name="HTTP to HTTPS" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{HTTPS}" pattern="^OFF$" />
          </conditions>
          <action type="Redirect" url="https://{HTTP_HOST}{REQUEST_URI}" redirectType="Permanent" />
        </rule>
        <!-- Encaminha /api para a API Node em localhost:3500 (quando você roda "npm run api" na pasta backend). Requer URL Rewrite + ARR. -->
        <rule name="Proxy API" stopProcessing="true">
          <match url="^api(/.*)?$" />
          <action type="Rewrite" url="http://localhost:3500/api{R:1}" />
        </rule>
        <!-- Raiz: domínio principal → busca (SEO) -->
        <rule name="Root to Search Landing" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^(www\.)?buscainfluencer\.(com|cm)\.br$" />
            <add input="{REQUEST_URI}" pattern="^/?(\?.*)?$" />
          </conditions>
          <action type="Rewrite" url="/landing/search/index.html" />
        </rule>
        <!-- Raiz: midiakit → landing principal (SEO) -->
        <rule name="Root to Midiakit Landing" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{HTTP_HOST}" pattern="^midiakit\.buscainfluencer\.com\.br$" />
            <add input="{REQUEST_URI}" pattern="^/?(\?.*)?$" />
          </conditions>
          <action type="Rewrite" url="/landing/index.html" />
        </rule>
        <!-- SPA: rotas que não são arquivo físico vão para index.html -->
        <rule name="SPA fallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
            <add input="{REQUEST_URI}" pattern="^/api" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>
    <staticContent>
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      <remove fileExtension=".woff" />
      <mimeMap fileExtension=".woff" mimeType="font/woff" />
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
    </staticContent>
  </system.webServer>
</configuration>
