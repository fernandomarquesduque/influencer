{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tunnel": "lt --port 5173 --subdomain influencer --local-host 127.0.0.1 --print-requests",
    "public": "concurrently -n dev,tunnel -c blue,yellow \"vite --port 5173 --strictPort\" \"powershell -NoProfile -Command Start-Sleep 12; lt --port 5173 --subdomain influencer --local-host 127.0.0.1 --print-requests\""
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.0",
    "@react-pdf/renderer": "^4.3.2",
    "antd": "^5.22.0",
    "pdfjs-dist": "^5.4.624",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.0.1"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "localtunnel": "^2.0.2",
    "typescript": "~5.9.3",
    "vite": "^7.2.4"
  }
}
