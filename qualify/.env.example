OLLAMA_HOST=http://localhost:11434
# llama3.2:3b costuma ser bem mais rapido em GPU 4GB (cabe inteiro na VRAM). Teste antes em producao.
# O qualify forca este valor do .env (override) — ignora OLLAMA_MODEL global do Windows/shell.
OLLAMA_MODEL=llama3.1:8b
# Inferencia: contexto menor e saida limitada aceleram (prompt fase1 ~1,8k tok).
OLLAMA_NUM_CTX=2048
OLLAMA_NUM_PREDICT=700
# Threads CPU quando parte do modelo roda fora da GPU (ex.: GTX 1050 4GB + llama3.1:8b). Use nucleos logicos - 1.
# OLLAMA_NUM_THREAD=7
QUALIFY_API_BASE=https://buscainfluencer.com.br/api
QUALIFY_INGEST_KEY=sua-chave-secreta-longa
QUALIFY_BATCH_SIZE=10
# Modo lote na API: use exatamente 1 (ou true/yes). Quantidade por request = QUALIFY_BATCH_SIZE acima.
# QUALIFY_LEGACY_QUEUE=1
QUALIFY_MAX_REASONING=3
QUALIFY_API_TIMEOUT_MS=30000
QUALIFY_INGEST_TIMEOUT_MS=120000
# Limite de posts nas legendas enviadas ao Ollama (fila e reparo).
QUALIFY_MEDIA_CONTEXT_LIMIT=10
# Prompt Ollama: tamanho das amostras (legendas truncadas; menos posts no JSON)
# QUALIFY_POST_SAMPLE_MAX_CHARS=220
# QUALIFY_PROMPT_POST_SAMPLE_LIMIT=6
# QUALIFY_PROMPT_POST_SAMPLES_MAX_TOTAL_CHARS=1200
# Fila batch: 1a passagem ja inclui legendas (collector-llm-pending includeContent=1). Desligar: 0
# QUALIFY_QUEUE_INCLUDE_CONTENT=0
# Log completo do prompt no console (1/true/yes). Padrao: off — evita poluir saida.
# QUALIFY_LOG_VERBOSE=1
# Particao da fila entre 2+ maquinas (hash estavel do handle). Maquina A: 0/2, maquina B: 1/2
# QUALIFY_SHARD=0/2
# QUALIFY_SHARD_INDEX=0
# QUALIFY_SHARD_COUNT=2
# CLI batch: reprocessar com LLM ja salvo (refreshAll) e filtrar categoria
# QUALIFY_ONLY_WITH_LLM=1
# QUALIFY_MAIN_CATEGORY=Beleza
# QUALIFY_BATCH_MAX_PROFILES=5
# Excluir perfis nao pt-br antes do Ollama (franc/heuristica). Desligar: 0
# QUALIFY_PRE_LLM_LANGUAGE_GATE=0
# Apos N erros de qualificacao (MANTIDO/erro), remove da base (padrao 2). Contador em data/llm-qualify-failures.json
# QUALIFY_LLM_FAIL_PURGE_AT=2
