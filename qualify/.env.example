OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
QUALIFY_API_BASE=https://buscainfluencer.com.br/api
QUALIFY_INGEST_KEY=sua-chave-secreta-longa
QUALIFY_BATCH_SIZE=20
QUALIFY_MAX_REASONING=3
QUALIFY_API_TIMEOUT_MS=30000
QUALIFY_INGEST_TIMEOUT_MS=120000
# Limite de posts quando o qualify busca legendas na 2a fase (só após falha de personaSummary).
QUALIFY_MEDIA_CONTEXT_LIMIT=10
# Sentimento por post apos qualificacao (CLI sem UI): 1/true/yes.
# QUALIFY_POST_SENTIMENT=1
# Sentimento por post: posts por chamada Ollama (1 = maxima precisao, 3 = padrao)
# Grava post.llm.sentiment = uma palavra (positivo|negativo) conforme o LLM.
# QUALIFY_SENTIMENT_BATCH_SIZE=3

# So sentimento, sem qualificar perfil (varre todos os perfis da base):
# QUALIFY_SENTIMENT_ONLY=1
# Log completo do prompt no console (1/true/yes). Padrao: off — evita poluir saida.
# QUALIFY_LOG_VERBOSE=1
